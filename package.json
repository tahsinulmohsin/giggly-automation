{
  "name": "giggly-product-automation",
  "version": "1.0.0",
  "description": "Automated product scraping, processing, and uploading system for giggly.shop",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dry-run": "node src/index.js --dry-run",
    "test-upload": "node src/index.js --test-upload --limit 1",
    "scrape-only": "node src/index.js --scrape-only",
    "sync-stock": "node src/index.js --sync-stock"
  },
  "keywords": [
    "ecommerce",
    "scraper",
    "automation",
    "woocommerce"
  ],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
