    "axios": "^1.13.6",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "node-cron": "^4.2.1",
    "p-limit": "^7.3.0",
    "winston": "^3.19.0",
    "xml2js": "^0.6.2"
  }
