# === Giggly Shop (Target) WooCommerce REST API ===
WC_URL=https://giggly.shop
WC_CONSUMER_KEY=ck_your_consumer_key_here
WC_CONSUMER_SECRET=cs_your_consumer_secret_here

# === Scraping Settings ===
# Interval in minutes between sitemap checks
MONITOR_INTERVAL_MINUTES=30
# Delay between scraping individual products (ms)
SCRAPE_DELAY_MS=2000
# Max concurrent image downloads
MAX_IMAGE_CONCURRENCY=3

# === Logging ===
LOG_LEVEL=info
